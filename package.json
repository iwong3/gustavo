{
    "name": "gustavo",
    "version": "0.0.1",
    "description": "track spending and split costs",
    "author": "Ivan Wong",
    "repository": "git+https://github.com/iwong3/gustavo.git",
    "engines": {
        "node": "24.x"
    },
    "scripts": {
        "build": "next build",
        "db:backfill": "node --env-file=.env.local scripts/backfill/import-expenses.js",
        "db:create-migration": "bash scripts/db/create-migration.sh",
        "db:migrate": "node --env-file=.env.local scripts/db/migrate.js",
        "db:migrate:prod": "node --env-file=.env.production.local scripts/db/migrate.js",
        "db:reset": "bash scripts/db/reset-database.sh",
        "db:seed": "node --env-file=.env.local scripts/db/seed.js",
        "db:test-as": "node --env-file=.env.local scripts/db/test-as.js",
        "dev": "next dev",
        "dev:reset": "bash scripts/db/reset-database.sh && next dev",
        "docker:down": "docker compose -f infra/docker-compose.yml down",
        "docker:logs": "docker compose -f infra/docker-compose.yml logs -f",
        "docker:up": "docker compose -f infra/docker-compose.yml up -d",
        "check:cycles": "madge --circular --extensions ts,tsx app/",
        "lint": "next lint",
        "start:local": "node scripts/app/start.js",
        "start": "next start",
        "test": "vitest run"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@emotion/cache": "^11.14.0",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "^7.3.11",
        "@mui/material": "^7.3.11",
        "@mui/material-nextjs": "^7.3.10",
        "@phosphor-icons/react": "^2.1.10",
        "@tabler/icons-react": "^3.44.0",
        "@tanstack/query-async-storage-persister": "^5.101.2",
        "@tanstack/react-query": "^5.101.2",
        "@tanstack/react-query-persist-client": "^5.101.2",
        "@visx/annotation": "^3.12.0",
        "@visx/axis": "^3.12.0",
        "@visx/brush": "^3.12.0",
        "@visx/curve": "^3.12.0",
        "@visx/group": "^3.12.0",
        "@visx/scale": "^3.12.0",
        "@visx/shape": "^3.12.0",
        "csv-parse": "^6.2.1",
        "dayjs": "^1.11.21",
        "fuse.js": "^7.4.2",
        "idb-keyval": "^6.3.0",
        "next": "^15.5.20",
        "next-auth": "5.0.0-beta.30",
        "next-pwa": "^5.6.0",
        "pg": "^8.22.0",
        "react": "^19.2.7",
        "react-animate-height": "^3.2.4",
        "react-colorful": "^5.7.0",
        "react-dom": "^19.2.7",
        "zustand": "^5.0.14"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.6",
        "@types/node": "^24.13.3",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "babel-loader": "^10.1.1",
        "eslint": "^9.39.5",
        "eslint-config-next": "^15.5.20",
        "eslint-plugin-react-hooks": "^7.1.1",
        "madge": "^8.0.0",
        "prettier": "^3.9.5",
        "typescript": "^5.9.3",
        "vitest": "^4.1.10"
    },
    "browserslist": {
        "production": [
            ">0.2%",
            "not dead",
            "not op_mini all"
        ],
        "development": [
            "last 1 chrome version",
            "last 1 firefox version",
            "last 1 safari version"
        ]
    },
    "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
    "pnpm": {
        "overrides": {
            "serialize-javascript": ">=7.0.3",
            "postcss@<8.5.10": ">=8.5.10"
        }
    }
}
