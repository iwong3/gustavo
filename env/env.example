# Environment variables for local development
# Copy this file to .env.local and fill in values

# =============================================================================
# LOCAL DEVELOPMENT (Docker PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://gus:yellow_shirt_dev@localhost:5432/gustavo_dev

# =============================================================================
# AUTH (Auth.js v5 — required in both local and production)
# Generate AUTH_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# =============================================================================
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# =============================================================================
# PRODUCTION (set in Vercel dashboard)
# =============================================================================
# DATABASE_URL=postgresql://...  (injected by Vercel + Neon integration)
# AUTH_SECRET=...
# AUTH_GOOGLE_ID=...
# AUTH_GOOGLE_SECRET=...
